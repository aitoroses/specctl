{
  "focus": {
    "lookup": {
      "reason": "charter_not_found"
    }
  },
  "next": {
    "mode": "choose_one",
    "options": [
      {
        "action": "create_charter",
        "choose_when": "The requested charter does not exist yet and must be created before any spec can live under it.",
        "kind": "run_command",
        "priority": 1,
        "template": {
          "argv": [
            "specctl",
            "charter",
            "create",
            "missing"
          ],
          "required_fields": [
            {
              "description": "Human-readable charter title",
              "name": "title"
            },
            {
              "description": "One-paragraph charter description",
              "name": "description"
            },
            {
              "description": "Initial group key",
              "name": "group_key"
            },
            {
              "description": "Initial group title",
              "name": "group_title"
            },
            {
              "description": "Integer group order",
              "name": "group_order"
            }
          ],
          "stdin_format": "yaml",
          "stdin_template": "title: \u003ctitle\u003e\ndescription: \u003cdescription\u003e\ngroups:\n  - key: \u003cgroup_key\u003e\n    title: \u003cgroup_title\u003e\n    order: \u003cgroup_order\u003e\n"
        },
        "why": "Create the charter first; spec creation has no standalone fallback."
      }
    ]
  },
  "state": {
    "charter": "missing",
    "tracking_file": null
  }
}
